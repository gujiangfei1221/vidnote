{
    "name": "vidnote",
    "version": "1.0.0",
    "description": "短视频 AI 知识萃取工具",
    "author": {
        "name": "gujiangfei",
        "email": "gujiangfei@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/gujiangfei/vidnote.git"
    },
    "main": "main.js",
    "scripts": {
        "start": "npx electron .",
        "dev": "npx electron . --dev",
        "build": "electron-builder --publish never",
        "build:mac": "electron-builder --mac --publish never",
        "build:win": "electron-builder --win --publish never",
        "build:linux": "electron-builder --linux --publish never"
    },
    "build": {
        "appId": "com.vidnote.app",
        "productName": "视频知识萃取器",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!resources/**"
        ],
        "extraResources": [
            {
                "from": "resources",
                "to": "bin",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "arm64"
                    ]
                }
            ],
            "icon": "assets/icon.icns",
            "category": "public.app-category.productivity"
        },
        "dmg": {
            "title": "视频知识萃取器",
            "artifactName": "vidnote-${version}-mac-arm64.${ext}"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.ico",
            "artifactName": "vidnote-${version}-win-x64.${ext}"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "assets/icon.ico",
            "uninstallerIcon": "assets/icon.ico"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "icon": "assets/icon.png",
            "category": "Utility",
            "artifactName": "vidnote-${version}-${arch}.${ext}"
        },
        "artifactName": "vidnote-${version}-${arch}.${ext}"
    },
    "devDependencies": {
        "electron": "^33.0.0",
        "electron-builder": "^25.0.0"
    },
    "dependencies": {
        "marked": "^15.0.0"
    }
}
