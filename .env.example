# 硅基流动 API Key (必需，用于 AI 总结，可以在 https://siliconflow.cn/ 申请获取)
SILICONFLOW_API_KEY=your_api_key_here

# 使用的模型 (支持 deepseek-ai/DeepSeek-V3 等)
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# Whisper 模型配置
# 默认为项目下的 models/ggml-base.bin，如果使用别的模型可以修改这里
WHISPER_MODEL_PATH=models/ggml-base.bin

# 外部工具路径
# 如果没有把 ffmpeg 等放入环境变量 PATH，可以在这里指定绝对路径
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# WHISPER_CPP_PATH=/absolute/path/to/whisper-cli

# 输出目录
# OUTPUT_DIR=output
